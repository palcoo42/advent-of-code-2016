			"problemMatcher": [
				"$rustc"
			],
			"group": "build",
			"label": "$(play) cargo run",
			"options": {"statusbar": {"color": "#7dcb8b"}},
			"presentation": {
				"clear": true
			},
		},
		{
			"type": "cargo",
			"command": "test",
			"args": [ "--package", "day_01_no_time_for_a_taxicab" ],
			"problemMatcher": [
				"$rustc"
			],
			"group": "test",
			"label": "$(play) cargo test",
			"options": {"statusbar": {"color": "#b17dcb"}},
			"presentation": {
				"clear": true
			}
		},
		{
			"type": "cargo",
			"command": "test",
			"args": [ "--package", "day_01_no_time_for_a_taxicab", "test_find_first_intersection", "--", "--nocapture" ],
			"problemMatcher": [
				"$rustc"
			],
			"group": "test",
			"label": "$(play) cargo test single",
			"options": {"statusbar": {"color": "#d8bd45ef"}},
			"presentation": {
				"clear": true
			}
		},
		{
			"type": "cargo",
			"command": "test",
			"args": [
				"--",
				"--include-ignored"
